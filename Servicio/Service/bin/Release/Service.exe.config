<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Paths -->
    <add key="procFile" value="GeneraSN.exe" />
    <add key="procPath" value="C:\Users\desa2\source\repos\GeneraSN\obj\Debug\" />
    <!-- Detalle Servicio -->
    <add key="name" value="Genera SN(Test)" />
    <add key="desc" value="Genera o Actualiza un SN desde Napse a Sap" />
    <!-- Frecuencia Timer (milisegundos) "60000" es 1 minuto/"3600000" es 1 hora -->
    <add key="frec" value="120000" />
    <!-- Programar Días -->
    <add key="Monday" value="1" />
    <add key="Tuesday" value="1" />
    <add key="Wednesday" value="1" />
    <add key="Thursday" value="1" />
    <add key="Friday" value="1" />
    <add key="Saturday" value="0" />
    <add key="Sunday" value="0" />
    <!-- Programar Horario -->
    <add key="desde" value="07:00:00" />
    <add key="hasta" value="22:00:00" />
    <!-- Correo -->
    <add key="mailFrom" value="envios.startechnology@gmail.com" />
    <add key="mailTo" value="delfina.gomez@startechnology.com.ar"/>
    <add key="mailCC" value="" />
    <add key="mailPass" value="bhbyeruejslbntcs" />
    <add key="asunto" value="Alerta sobre el servicio: " />
    <add key="cuerpo" value="" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>